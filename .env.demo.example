# Env vars for docker-compose.demo.yml. Copy to .env.demo and fill in.
# Everything else the demo instance needs is hardcoded in the compose file
# itself — this template only covers the two values that must be unique to
# your deployment.

# A secret dedicated to the demo instance. Never reuse the real instance's
# AUTH_SECRET. Generate with: openssl rand -base64 32
DEMO_AUTH_SECRET=""

# The public URL visitors will use, e.g. https://demo.yourdomain.com
DEMO_APP_URL="https://demo.example.com"
