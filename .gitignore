# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.demo.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# database
/prisma/dev.db
/prisma/dev.db-journal
*.db
*.db-journal

# local self-hosted data (sqlite file + uploaded documents)
/data

# TLS certificates (self-signed or real) — never commit private keys
/certs

# e2e test suite: ephemeral DB/uploads/auth state regenerated on every run
/e2e/.data
/playwright-report
/test-results

# service worker built artifact (regenerated by @serwist/next at build time)
/public/sw.js
/public/sw.js.map

# Android build artifacts (generated by Gradle — not committed)
/android/.gradle
/android/app/build
/android/build
/android/local.properties
*.keystore
!debug.keystore

