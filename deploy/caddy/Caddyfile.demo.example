# Example Caddyfile for exposing the public demo instance (see
# docker-compose.demo.yml) on its own subdomain with automatic HTTPS.
#
# This is the opposite concern from deploy/nginx/hearth-mtls.conf.example,
# which locks a *private* instance down behind client certificates — the
# demo instance needs to be wide open to the public instead, so a plain
# Caddy reverse_proxy with Caddy's built-in automatic TLS is the simplest
# correct setup, no cert management of your own required.
#
# Replace demo.example.com with your real subdomain, then:
#   caddy reload --config /path/to/Caddyfile

demo.example.com {
    reverse_proxy 127.0.0.1:3001
}
