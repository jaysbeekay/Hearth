generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  MEMBER
}

enum ContractCategory {
  RENTAL
  CAR_INSURANCE
  HOME_INSURANCE
  STRATA_INSURANCE
  HEALTH_INSURANCE
  LIFE_INSURANCE
  UTILITY
  TELECOM
  SUBSCRIPTION
  LOAN
  WARRANTY
  OTHER
}

enum RenewalType {
  AUTO_RENEW
  MANUAL_RENEWAL
  FIXED_TERM
}

enum BillingFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
  ONE_OFF
}

enum ContractStatus {
  ACTIVE
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  NTFY
  WEBHOOK
}

enum ProductDocumentKind {
  INVOICE
  PHOTO
  MANUAL
  OTHER
}

enum AiProvider {
  ANTHROPIC
  GEMINI
  OPENAI
}

enum BackupDestination {
  S3
  SFTP
}

enum BackupStatus {
  SUCCESS
  FAILURE
}

enum ModuleKey {
  TRAVEL
  HOME
  VEHICLES
  INVENTORY
  WEALTH
}

enum AssetClass {
  SHARE
  ETF
  MANAGED_FUND
  CRYPTO
  CASH
  OTHER
}

enum TradeType {
  BUY
  SELL
  DIVIDEND
  SPLIT
}

enum InventoryItemCategory {
  APPLIANCE
  ELECTRONICS
  FURNITURE
  TOOL
  CLOTHING
  SPORTING
  BOOK
  MEDIA
  OTHER
}

enum VehicleItemType {
  SERVICE
  REPAIR
  REGISTRATION
  INSURANCE
  ROADWORTHY
  MODIFICATION
  OTHER
}

enum TripSegmentType {
  FLIGHT
  LODGING
  ACTIVITY
}

enum HomeItemType {
  MAINTENANCE
  IMPROVEMENT
  REPAIR
  OTHER
}

model User {
  id                String     @id @default(cuid())
  name              String
  email             String     @unique
  passwordHash      String
  role              Role       @default(MEMBER)
  emailReminders    Boolean    @default(true)
  aiProvider        AiProvider?
  aiApiKeyEncrypted String?
  aiModel           String?
  icalToken         String?    @unique
  createdAt         DateTime   @default(now())
  contracts         Contract[]
  products          Product[]
  webhookEndpoints  WebhookEndpoint[]
  trips             Trip[]
  properties        Property[]
  passkeys          PasskeyCredential[]
  vehicles          Vehicle[]
  inventoryItems    InventoryItem[]
  portfolios        Portfolio[]

  @@map("users")
}

model PasskeyCredential {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique
  publicKey    Bytes
  counter      Int       @default(0)
  transports   String?
  nickname     String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
  @@map("passkey_credentials")
}

model PasskeyChallenge {
  id        String   @id @default(cuid())
  userId    String?
  challenge String   @unique
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("passkey_challenges")
}

model Contract {
  id                String        @id @default(cuid())
  title             String
  category          ContractCategory
  provider          String
  contractNumber    String?
  startDate         DateTime?
  endDate           DateTime?
  renewalType       RenewalType   @default(MANUAL_RENEWAL)
  noticePeriodDays  Int?
  cost              Float?
  currency          String        @default("AUD")
  billingFrequency  BillingFrequency?
  status            ContractStatus @default(ACTIVE)
  contactName       String?
  contactPhone      String?
  contactEmail      String?
  notes             String?
  reminderDaysBefore String?      @default("30,14,7,1")
  isTaxDeductible   Boolean       @default(false)

  createdById       String
  createdBy         User          @relation(fields: [createdById], references: [id])

  documents         Document[]
  notifications     NotificationLog[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("contracts")
}

model Document {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  filename   String
  storedName String
  mimeType   String
  size       Int
  uploadedAt DateTime @default(now())

  @@map("documents")
}

model NotificationLog {
  id            String              @id @default(cuid())
  contractId    String
  contract      Contract            @relation(fields: [contractId], references: [id], onDelete: Cascade)
  channel       NotificationChannel
  thresholdDays Int
  sentAt        DateTime            @default(now())

  @@unique([contractId, channel, thresholdDays])
  @@map("notification_logs")
}

model Product {
  id                 String    @id @default(cuid())
  name               String
  manufacturer       String?
  vendor             String?
  serialNumber       String?
  barcode            String?
  purchaseDate       DateTime?
  warrantyEndDate    DateTime?
  price              Float?
  currency           String    @default("AUD")
  notes              String?
  reminderDaysBefore String?   @default("30,14,7,1")

  createdById        String
  createdBy          User      @relation(fields: [createdById], references: [id])

  documents          ProductDocument[]
  notifications      ProductNotificationLog[]

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("products")
}

model ProductDocument {
  id         String              @id @default(cuid())
  productId  String
  product    Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  filename   String
  storedName String
  mimeType   String
  size       Int
  kind       ProductDocumentKind @default(OTHER)
  uploadedAt DateTime            @default(now())

  @@map("product_documents")
}

model ProductNotificationLog {
  id            String              @id @default(cuid())
  productId     String
  product       Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  channel       NotificationChannel
  thresholdDays Int
  sentAt        DateTime            @default(now())

  @@unique([productId, channel, thresholdDays])
  @@map("product_notification_logs")
}

model AppSetting {
  key       String   @id
  value     String?
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model BackupLog {
  id          String            @id @default(cuid())
  destination BackupDestination
  status      BackupStatus
  fileName    String?
  sizeBytes   Int?
  message     String?
  startedAt   DateTime          @default(now())
  finishedAt  DateTime?

  @@map("backup_logs")
}

model WebhookEndpoint {
  id          String       @id @default(cuid())
  name        String
  url         String
  secret      String?
  enabled     Boolean      @default(true)

  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id])

  logs        WebhookLog[]

  createdAt   DateTime     @default(now())

  @@map("webhook_endpoints")
}

model WebhookLog {
  id         String          @id @default(cuid())
  endpointId String
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  event      String
  success    Boolean
  statusCode Int?
  message    String?
  sentAt     DateTime        @default(now())

  @@map("webhook_logs")
}

model ModuleEnablement {
  id        String    @id @default(cuid())
  key       ModuleKey @unique
  enabled   Boolean   @default(false)
  updatedAt DateTime  @updatedAt

  @@map("module_enablements")
}

model Trip {
  id          String        @id @default(cuid())
  title       String
  destination String?
  startDate   DateTime?
  endDate     DateTime?
  notes       String?

  createdById String
  createdBy   User          @relation(fields: [createdById], references: [id])

  segments    TripSegment[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("trips")
}

model TripSegment {
  id               String                @id @default(cuid())
  tripId           String
  trip             Trip                  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  type             TripSegmentType
  title            String
  provider         String?
  confirmationCode String?
  startDate        DateTime?
  endDate          DateTime?
  location         String?
  cost             Float?
  currency         String                @default("AUD")
  notes            String?

  documents        TripSegmentDocument[]

  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@map("trip_segments")
}

model TripSegmentDocument {
  id            String      @id @default(cuid())
  tripSegmentId String
  tripSegment   TripSegment @relation(fields: [tripSegmentId], references: [id], onDelete: Cascade)
  filename      String
  storedName    String
  mimeType      String
  size          Int
  uploadedAt    DateTime    @default(now())

  @@map("trip_segment_documents")
}

model Property {
  id          String  @id @default(cuid())
  label       String
  address     String?
  notes       String?
  isRented    Boolean @default(false)

  createdById String
  createdBy   User    @relation(fields: [createdById], references: [id])

  items             HomeItem[]
  rentalAgreements  RentalAgreement[]
  rentalStatements  RentalStatement[]
  valuations        PropertyValuation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("properties")
}

model RentalAgreement {
  id                   String    @id @default(cuid())
  propertyId           String
  property             Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenantName           String?
  weeklyRent           Float
  managementFeePercent Float?
  leaseStart           DateTime?
  leaseEnd             DateTime?
  bondAmount           Float?
  currency             String    @default("AUD")
  notes                String?
  createdAt            DateTime  @default(now())

  @@map("rental_agreements")
}

model RentalStatement {
  id              String                    @id @default(cuid())
  propertyId      String
  property        Property                  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  periodStart     DateTime?
  periodEnd       DateTime?
  statementDate   DateTime?
  grossRent       Float?
  managementFee   Float?
  otherDeductions Float?
  netAmount       Float?
  currency        String                    @default("AUD")
  notes           String?
  documents       RentalStatementDocument[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@map("rental_statements")
}

model RentalStatementDocument {
  id                String          @id @default(cuid())
  rentalStatementId String
  rentalStatement   RentalStatement @relation(fields: [rentalStatementId], references: [id], onDelete: Cascade)
  filename          String
  storedName        String
  mimeType          String
  size              Int
  uploadedAt        DateTime        @default(now())

  @@map("rental_statement_documents")
}

model HomeItem {
  id         String             @id @default(cuid())
  propertyId String
  property   Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  type       HomeItemType
  title      String
  provider   String?
  date       DateTime?
  cost       Float?
  currency   String             @default("AUD")
  isTaxDeductible Boolean       @default(false)
  notes      String?

  documents  HomeItemDocument[]

  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@map("home_items")
}

model HomeItemDocument {
  id         String   @id @default(cuid())
  homeItemId String
  homeItem   HomeItem @relation(fields: [homeItemId], references: [id], onDelete: Cascade)
  filename   String
  storedName String
  mimeType   String
  size       Int
  uploadedAt DateTime @default(now())

  @@map("home_item_documents")
}

model Vehicle {
  id                 String    @id @default(cuid())
  label              String
  make               String?
  model              String?
  year               Int?
  colour             String?
  licensePlate       String?
  vin                String?
  regoExpiry         DateTime?
  insuranceExpiry    DateTime?
  reminderDaysBefore String?   @default("30,14,7,1")
  notes              String?

  createdById        String
  createdBy          User      @relation(fields: [createdById], references: [id])

  items              VehicleItem[]
  notificationLogs   VehicleNotificationLog[]

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("vehicles")
}

model VehicleItem {
  id          String          @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type        VehicleItemType
  title       String
  provider    String?
  date        DateTime?
  cost        Float?
  currency    String          @default("AUD")
  notes       String?

  documents   VehicleItemDocument[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("vehicle_items")
}

model VehicleItemDocument {
  id            String      @id @default(cuid())
  vehicleItemId String
  vehicleItem   VehicleItem @relation(fields: [vehicleItemId], references: [id], onDelete: Cascade)
  filename      String
  storedName    String
  mimeType      String
  size          Int
  uploadedAt    DateTime    @default(now())

  @@map("vehicle_item_documents")
}

model VehicleNotificationLog {
  id            String   @id @default(cuid())
  vehicleId     String
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  channel       String
  thresholdDays Int
  field         String
  sentAt        DateTime @default(now())

  @@unique([vehicleId, channel, thresholdDays, field])
  @@map("vehicle_notification_logs")
}

model InventoryItem {
  id            String                @id @default(cuid())
  label         String
  category      InventoryItemCategory @default(OTHER)
  brand         String?
  model         String?
  serialNumber  String?
  purchaseDate  DateTime?
  purchasePrice Float?
  currency      String                @default("AUD")
  location      String?
  notes         String?

  documents     InventoryItemDocument[]

  createdById   String
  createdBy     User                  @relation(fields: [createdById], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("inventory_items")
}

model InventoryItemDocument {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  filename        String
  storedName      String
  mimeType        String
  size            Int
  uploadedAt      DateTime      @default(now())

  @@map("inventory_item_documents")
}

model Portfolio {
  id          String    @id @default(cuid())
  name        String
  description String?
  currency    String    @default("AUD")
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  holdings    Holding[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("portfolios")
}

model Holding {
  id          String     @id @default(cuid())
  portfolioId String
  portfolio   Portfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  ticker      String
  name        String?
  assetClass  AssetClass @default(SHARE)
  exchange    String?
  trades      Trade[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([portfolioId, ticker])
  @@map("holdings")
}

model Trade {
  id                 String          @id @default(cuid())
  holdingId          String
  holding            Holding         @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  type               TradeType
  date               DateTime
  units              Float
  pricePerUnit       Float
  marketPriceOnDate  Float?
  fees               Float?
  currency           String          @default("AUD")
  fxRate             Float?
  notes              String?
  documents          TradeDocument[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@map("trades")
}

model TradeDocument {
  id         String   @id @default(cuid())
  tradeId    String
  trade      Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  filename   String
  storedName String
  mimeType   String
  size       Int
  uploadedAt DateTime @default(now())

  @@map("trade_documents")
}

model PriceCache {
  ticker    String   @id
  price     Float
  currency  String   @default("AUD")
  changePct Float?
  source    String
  cachedAt  DateTime

  @@map("price_cache")
}

model PriceHistory {
  id       String   @id @default(cuid())
  ticker   String
  date     DateTime
  close    Float
  adjClose Float?
  source   String

  @@unique([ticker, date])
  @@map("price_history")
}

model PropertyValuation {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  valuedAt   DateTime
  value      Float
  currency   String   @default("AUD")
  source     String?
  notes      String?
  createdAt  DateTime @default(now())

  @@map("property_valuations")
}
